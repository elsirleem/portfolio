# Copy this file to .env.local and fill in your Formspree form ID.
# Get one at https://formspree.io — sign up free, create a new form,
# verify the destination email (yours), and copy the form ID from the
# endpoint they give you. Either the bare ID or the full URL works:
#   NEXT_PUBLIC_FORMSPREE_ID=xykqoygv
#   NEXT_PUBLIC_FORMSPREE_ID=https://formspree.io/f/xykqoygv
#
# IMPORTANT: restart `npm run dev` (or rebuild) after changing this file —
# Next.js only reads NEXT_PUBLIC_* env vars when the server starts, it does
# not hot-reload them.
NEXT_PUBLIC_FORMSPREE_ID=
